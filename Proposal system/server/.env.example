# Server Configuration
PORT=5000
SESSION_SECRET=your_long_secure_session_secret_key_here

# Client Portal Configuration (Frontend URL)
FRONTEND_URL=http://localhost:5500

# Xero API OAuth 2.0 Credentials
# Get these by creating an app at https://developer.xero.com/
XERO_CLIENT_ID=your_xero_client_id_here
XERO_CLIENT_SECRET=your_xero_client_secret_here

# Must match exactly what is registered in the Xero Developer Portal
# For local testing, this endpoint on the backend will handle the exchange
XERO_REDIRECT_URI=http://localhost:5000/auth/callback

# SMTP Mail Server Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Sale by Design Homes" <proposals@salebydesignhomes.com.au>
